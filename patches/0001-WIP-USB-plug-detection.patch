+package org.fdroid.fdroid.localrepo;
+
+import android.content.Intent;
+import android.os.Bundle;
+import android.support.v7.app.AppCompatActivity;
+import android.widget.Toast;
+import org.fdroid.fdroid.R;
+
+public class UsbStorageActivity extends AppCompatActivity {
+
+    @Override
+    protected void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        setContentView(R.layout.activity_usb_storage);
+        Intent intent = getIntent();
+        Toast.makeText(this, "Got INTENT: " + intent, Toast.LENGTH_LONG).show();
+
+        // TODO Get mounted broadcast to check for fdroid repo.
+    }
+}
